# WhatsApp IP - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# WhatsApp Business Cloud API
# ============================================
# Get these from: https://developers.facebook.com/apps/
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_NUMBER_ID_US=your_us_phone_number_id
WHATSAPP_PHONE_NUMBER_ID_MX=your_mexican_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_APP_ID=your_app_id
WHATSAPP_APP_SECRET=your_app_secret

# Webhook Configuration
WEBHOOK_VERIFY_TOKEN=your_custom_verification_token_here

# ============================================
# Google Workspace APIs
# ============================================
# OAuth 2.0 Credentials (download JSON from Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_for_contacts

# Google Docs Folder (for conversation logs)
GOOGLE_DOCS_FOLDER_ID=your_folder_id

# ============================================
# AI/LLM Service
# ============================================
# Choose one: OpenAI or Google Gemini
OPENAI_API_KEY=your_openai_api_key_here
# OR
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# Model selection
AI_MODEL=gpt-4
# AI_MODEL=gemini-pro

# ============================================
# Database
# ============================================
DATABASE_URL=sqlite:///whatsapp_ip.db
# For production: postgresql://user:password@localhost/whatsapp_ip

# ============================================
# Application Configuration
# ============================================
ENVIRONMENT=development
# ENVIRONMENT=production

FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# Server Configuration
HOST=0.0.0.0
PORT=8000

# ============================================
# Security
# ============================================
SECRET_KEY=your_flask_secret_key_here
ENCRYPTION_KEY=your_encryption_key_for_sensitive_data

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG
