# Clave de la API de Anthropic (Claude). Requerida para correr el bot con API real.
ANTHROPIC_API_KEY=
# Modelo de Claude a usar (default claude-sonnet-5 si se deja vacio)
MODEL=claude-sonnet-5
# Nivel de esfuerzo del modelo: low, medium o high (default low)
EFFORT=low
# Token personal de Airtable (para guardar leads en la base)
AIRTABLE_TOKEN=
# ID de la base de Airtable donde vive la tabla de Leads
AIRTABLE_BASE_ID=
# Nombre de la tabla de Leads dentro de la base (default Leads)
AIRTABLE_TABLE_LEADS=Leads
# Token de acceso de WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=
# ID del numero de telefono de WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
# Token de verificacion del webhook (lo defines tu, Meta lo manda de vuelta)
WHATSAPP_VERIFY_TOKEN=
# Si es true, las respuestas del bot se guardan pendientes en vez de enviarse solas (Fase 1/2)
COPILOT_MODE=true
# API key de CallMeBot, para el ping opcional de WhatsApp cuando hay un lead caliente
CALLMEBOT_APIKEY=
# Numero de telefono registrado en CallMeBot (quien recibe el ping)
CALLMEBOT_PHONE=
# Maximo de intercambios antes de forzar el cierre de la conversacion (default 12)
MAX_TURNS=12
