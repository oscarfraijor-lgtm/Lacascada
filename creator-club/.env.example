# Airtable (cuando cableemos datos reales). Sin esto, la app guarda en archivo local.
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=

# Marca activa: slug que debe existir en lib/brands.ts (color-dreams, demo, …).
# Cada deploy usa SU marca + SU AIRTABLE_BASE_ID (una base por marca).
NEXT_PUBLIC_BRAND=color-dreams

# Login por correo (magic link). Secreto para firmar los enlaces (HMAC).
# Genera uno con:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Envío de correo con Resend. Sin key, el enlace se imprime en terminal (modo dev).
RESEND_API_KEY=
# MULTIMARCA: una sola cuenta + un solo dominio Resend para TODAS las marcas. Pon
# aquí solo la dirección compartida; el nombre visible se arma solo con cada marca
# ("Color Club", "Anyeluz Club", ...), así el MISMO valor sirve en todos los deploys.
RESEND_FROM_ADDRESS=no-reply@club.indiepro.com.mx
# (Opcional) override TOTAL del remitente. Si defines RESEND_FROM_ADDRESS, ignora esto.
RESEND_FROM=

# Panel de admin: correos con acceso a /admin (separados por coma)
ADMIN_EMAILS=

# Acceso de admin con CLAVE del equipo (OPCIONAL): alternativa al magic link para
# entrar a /console sin correo. Si está vacío, la opción ni aparece. La clave NO crea
# admins nuevos (el correo debe estar igual en ADMIN_EMAILS / lib/roles). Usa una
# frase LARGA y aleatoria; no la commitees; rótala si se filtra.
# Genera una con:  node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_PASSPHRASE=

# Piso global de GMV (MXN) para aprobar/entregar CUALQUIER recompensa con costo
# (anti-fuga). Vacío o 0 = sin piso global (cada recompensa usa su propio umbral;
# una puede atarse a "tu primera venta"). Define un número para que ninguna
# recompensa con costo se entregue por debajo de ese GMV. Ej: 5000
GMV_MIN_PARA_COSTO=
