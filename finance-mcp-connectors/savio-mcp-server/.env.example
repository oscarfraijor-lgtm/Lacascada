# Savio API Credentials
# Contacta a nacho@savio.mx para obtener tu API Key

# API Key de Savio
SAVIO_API_KEY=your_savio_api_key_here

# Environment (sandbox o production)
SAVIO_ENVIRONMENT=sandbox

# Base URL (se configura automáticamente según environment)
# sandbox: https://api-sandbox.savio.mx/api/v1
# production: https://api-savio.mx/api/v1
SAVIO_BASE_URL=https://api-sandbox.savio.mx/api/v1

# Puerto del servidor MCP
MCP_SERVER_PORT=3002
