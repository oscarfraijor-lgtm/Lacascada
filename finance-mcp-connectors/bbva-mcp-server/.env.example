# BBVA API Credentials
# Obtén estas credenciales en: https://www.bbvaapimarket.com/

# API Key de BBVA API Market
BBVA_API_KEY=your_api_key_here

# Client ID (OAuth)
BBVA_CLIENT_ID=your_client_id_here

# Client Secret (OAuth)
BBVA_CLIENT_SECRET=your_client_secret_here

# Environment (sandbox o production)
BBVA_ENVIRONMENT=sandbox

# Base URL (se configura automáticamente según environment)
# sandbox: https://apis.bbva.com/sandbox
# production: https://apis.bbva.com
BBVA_BASE_URL=https://apis.bbva.com/sandbox

# Puerto del servidor MCP
MCP_SERVER_PORT=3003
